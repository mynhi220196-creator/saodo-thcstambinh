# Firebase — Project settings → Your apps → Web app (SDK snippet)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firestore: profiles.role = ADMIN | TEACHER | RED_STAR (GVCN qua homeroom_assignments / phân công lớp, không lưu trong role).
# Deploy rules: firestore.rules (ADMIN: profiles, classes, students).
# Collections: classes (code, grade, school_year, homeroom_teacher_id, room, is_active),
# students (student_code, full_name, gender, date_of_birth, class_id, guardian_phone, is_deleted).

# Bắt buộc chỉ user có profiles.role = ADMIN đăng nhập khu /admin (mặc định: bật).
# Đặt false nếu cần test nhanh với vai trò khác (không khuyến nghị production).
# VITE_REQUIRE_ADMIN_ROLE=false

# Cloudinary — ảnh minh chứng tác phong (upload unsigned từ trình duyệt)
# Dashboard → Settings → Upload → Upload presets → tạo preset dạng Unsigned, folder tuỳ chọn (vd: saodo/conduct).
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
